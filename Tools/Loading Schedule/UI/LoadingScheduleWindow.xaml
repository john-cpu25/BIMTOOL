<Window x:Class="RincoNhan.Tools.LoadingSchedule.UI.LoadingScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Schedule Legend" Height="600" Width="850"
        WindowStartupLocation="CenterScreen" Background="#FFF5F5F5"
        MinHeight="450" MinWidth="700">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#FF2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#FFE0E0E0"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFBDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SmallButton">
            <Setter Property="Background" Value="#FFE0E0E0"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFBDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Loading Schedule Legend" 
                   FontWeight="Bold" FontSize="18" Foreground="#FF1565C0" Margin="0,0,0,10"/>

        <!-- Settings Panel -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,10"
                BorderBrush="#FFE0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: Template Legend -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="📋 Template Legend:" 
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbTemplateLegend"
                          ItemsSource="{Binding TemplateLegendViews}"
                          SelectedItem="{Binding SelectedTemplateLegend}"
                          DisplayMemberPath="Name" Height="28"/>

                <!-- Separator -->
                <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,2"/>

                <!-- Row 2: Create New Legend -->
                <RadioButton Grid.Row="2" Grid.Column="0" x:Name="rbCreateNew" 
                             Content="Create new legend:" IsChecked="True"
                             VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"
                             GroupName="LegendMode" Checked="LegendMode_Changed"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtLegendName"
                         Text="Loading Schedule" Height="28" VerticalContentAlignment="Center"
                         Padding="6,0" BorderBrush="#FFCCCCCC" BorderThickness="1"/>

                <!-- Row 4: Use Existing Legend -->
                <RadioButton Grid.Row="4" Grid.Column="0" x:Name="rbUseExisting"
                             Content="Use existing legend:" IsChecked="False"
                             VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"
                             GroupName="LegendMode" Checked="LegendMode_Changed"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbTargetLegend"
                          ItemsSource="{Binding TargetLegendViews}"
                          SelectedItem="{Binding SelectedTargetLegend}"
                          DisplayMemberPath="Name" Height="28" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- Data Grid: Filled Region Types from current view -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="2"
                BorderBrush="#FFE0E0E0" BorderThickness="1">
            <DataGrid x:Name="dgItems" ItemsSource="{Binding Items}" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" 
                      AlternatingRowBackground="#FFF8F9FA"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#FFE8E8E8"
                      BorderThickness="0"
                      SelectionMode="Single"
                      RowHeight="28">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="35"/>
                    <DataGridTextColumn Header="N.o" Binding="{Binding Number}" Width="40" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Pattern" Binding="{Binding PatternName}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Color (R,G,B)" Binding="{Binding ColorDisplay}" Width="100" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Reorder Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="▲ Move Up" Style="{StaticResource SmallButton}" Click="MoveUp_Click" Margin="0,0,5,0"/>
            <Button Content="▼ Move Down" Style="{StaticResource SmallButton}" Click="MoveDown_Click" Margin="0,0,5,0"/>
            <Button Content="☑ Select All" Style="{StaticResource SmallButton}" Click="SelectAll_Click" Margin="0,0,5,0"/>
            <Button Content="☐ Deselect All" Style="{StaticResource SmallButton}" Click="DeselectAll_Click"/>
        </StackPanel>

        <!-- Template Status -->
        <Border Grid.Row="4" Background="#FFF3E5F5" CornerRadius="4" Padding="10" Margin="0,8,0,0"
                BorderBrush="#FFCE93D8" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Status:" FontWeight="SemiBold" FontSize="11" Foreground="#FF6A1B9A" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtTemplateStatus" Text="{Binding TemplateStatusMessage}" 
                           FontSize="11" Foreground="#FF4A148C" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnToggleLog" Content="▶ Show Log" Style="{StaticResource SmallButton}" 
                    Click="ToggleLog_Click" Margin="0,0,10,0"/>
            <ProgressBar x:Name="progressBar" IsIndeterminate="True" Width="120" Height="6" 
                         VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"
                         Foreground="#FF2196F3" Background="#FFE0E0E0"/>
            <TextBlock x:Name="txtStatus" Text="" VerticalAlignment="Center" 
                       Foreground="#FF757575" FontSize="12" Margin="0,0,15,0"/>
            <Button x:Name="btnCreate" Content="Create Legend" Style="{StaticResource ActionButton}" Click="CreateLegend_Click" Margin="0,0,8,0"/>
            <Button Content="Close" Style="{StaticResource SecondaryButton}" Click="Close_Click"/>
        </StackPanel>

        <!-- Debug Log Panel -->
        <Border Grid.Row="6" x:Name="logPanel" Background="#FF1E1E1E" CornerRadius="4" 
                Padding="8" Margin="0,8,0,0" Visibility="Collapsed" MaxHeight="150">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="🔍 Debug Log" FontWeight="SemiBold" FontSize="11" 
                               Foreground="#FF4FC3F7" VerticalAlignment="Center"/>
                    <Button Content="Clear" Style="{StaticResource SmallButton}" Click="ClearLog_Click"
                            Margin="10,0,0,0" FontSize="10" Padding="6,2"/>
                </StackPanel>
                <TextBox Grid.Row="1" x:Name="txtLog" IsReadOnly="True" 
                         Background="#FF1E1E1E" Foreground="#FFB0BEC5" 
                         BorderThickness="0" FontFamily="Consolas" FontSize="11"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
