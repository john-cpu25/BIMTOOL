<Window x:Class="RincoNhan.Tools.AutoViewSheet.UI.AutoViewSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Auto View &amp; Sheet Tool" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        Background="#F5F7F9">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E5C9A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#2E5C9A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="30"/>
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F7F9"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" Margin="10" Background="White" BorderBrush="#DCDDE1">
            <!-- TAB 1: AUTO PROCESS -->
            <TabItem Header="Auto Process">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Search:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0" Foreground="#2C3E50"/>
                            <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="26" VerticalContentAlignment="Center" Margin="0,0,15,0" ToolTip="Search by Sheet Name, Number, or Level"/>

                            <Button Content="Sort A-Z/Z-A" Command="{Binding ToggleSortCommand}" Padding="8,4" Background="White" BorderBrush="#DCDDE1" Margin="0,0,15,0" Cursor="Hand"/>

                            <Button Content="Expand All" Click="BtnExpandAll_Click" Padding="8,4" Background="White" BorderBrush="#DCDDE1" Margin="0,0,5,0" Cursor="Hand"/>
                            <Button Content="Collapse All" Click="BtnCollapseAll_Click" Padding="8,4" Background="White" BorderBrush="#DCDDE1" Margin="0,0,15,0" Cursor="Hand"/>
                            
                            <Button Content="Check All" Command="{Binding SelectAllCommand}" CommandParameter="True" Padding="8,4" Background="White" BorderBrush="#DCDDE1" Margin="0,0,5,0" Cursor="Hand"/>
                            <Button Content="Uncheck All" Command="{Binding SelectAllCommand}" CommandParameter="False" Padding="8,4" Background="White" BorderBrush="#DCDDE1" Cursor="Hand"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Column="1" Text="Each row creates a View, creates a Sheet, sets ScopeBox, adds to Sheet, sets Title, and aligns it." VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#7F8C8D" FontStyle="Italic"/>
                    </Grid>

                    <DataGrid Grid.Row="1" x:Name="MainDataGrid" ItemsSource="{Binding AutoRowsView}" Style="{StaticResource DataGridStyle}" ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}">
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True" BorderBrush="#DCDDE1" BorderThickness="1" Background="#F8FAFC">
                                                        <Expander.Header>
                                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                                <CheckBox IsChecked="{Binding Items[0].IsGroupSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,10,0" VerticalAlignment="Center"/>
                                                                <ComboBox ItemsSource="{Binding DataContext.ProjectLevels, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Items[0].SelectedLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" Width="140" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                                <TextBox Text="{Binding Items[0].SheetNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="0,0,5,0" FontWeight="Bold" Background="Transparent" BorderThickness="0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="-" Margin="5,0" VerticalAlignment="Center" Foreground="#2C3E50"/>
                                                                <TextBox Text="{Binding Items[0].SheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="400" FontWeight="Bold" Background="Transparent" BorderThickness="0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Suffix" Binding="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                            <DataGridTemplateColumn Header="View Type" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ViewTypes, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                  SelectedItem="{Binding SelectedViewType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  DisplayMemberPath="Name" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="View Template" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ViewTemplates, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                  SelectedItem="{Binding SelectedViewTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  DisplayMemberPath="Name" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>


                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- TAB 2: GLOBAL SETTINGS -->
            <TabItem Header="Global Settings">
                <StackPanel Margin="20">
                    <TextBlock Text="These settings apply to all sheets and views created in the Auto Process tab." 
                               Foreground="#7F8C8D" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="1. TitleBlock for New Sheets" Style="{StaticResource SectionLabel}"/>
                    <ComboBox ItemsSource="{Binding TitleBlocks}" SelectedItem="{Binding SelectedTitleBlock}" 
                              DisplayMemberPath="Name" Width="400" HorizontalAlignment="Left" Height="28" Margin="0,0,0,15"/>

                    <TextBlock Text="2. Sheet Series Parameter" Style="{StaticResource SectionLabel}"/>
                    <ComboBox ItemsSource="{Binding SheetSeriesOptions}" Text="{Binding SelectedSheetSeries, UpdateSourceTrigger=PropertyChanged}" 
                              IsEditable="True" Width="400" HorizontalAlignment="Left" Height="28" Margin="0,0,0,15"/>

                    <TextBlock Text="3. Viewport Title Type (Turn On Title)" Style="{StaticResource SectionLabel}"/>
                    <ComboBox ItemsSource="{Binding ViewportTitleTypes}" SelectedItem="{Binding SelectedViewportTitle}" 
                              DisplayMemberPath="Name" Width="400" HorizontalAlignment="Left" Height="28" Margin="0,0,0,15"/>

                    <TextBlock Text="4. Global Scope Box" Style="{StaticResource SectionLabel}"/>
                    <TextBlock Text="Apply this Scope Box to all created views." Foreground="#7F8C8D" FontSize="11" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding ScopeBoxOptions}" SelectedItem="{Binding SelectedGlobalScopeBox}" 
                              DisplayMemberPath="Name" Width="400" HorizontalAlignment="Left" Height="28" Margin="0,0,0,15"/>

                    <TextBlock Text="5. Stack Views (Place all views at the same center point)" Style="{StaticResource SectionLabel}"/>
                    <CheckBox Content="Stack Views on Sheet" IsChecked="{Binding StackViews}" IsEnabled="False" Margin="0,0,0,15"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#34495E" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Run Auto Process" Command="{Binding RunAutoProcessCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="150" Background="#E67E22"/>
                    <Button Content="Close" Click="CloseButton_Click" Style="{StaticResource PrimaryButtonStyle}" Background="#95A5A6" Margin="10,0,0,0" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
