<Window x:Class="RincoNhan.Tools.Auto_Dim_Grid.UI.AutoDimGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Auto Dim Grid" Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#FFF5F5F5"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#FF2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <TabControl Background="Transparent" BorderThickness="0" Margin="10">
            <!-- Tab 1: Dim Grid -->
            <TabItem Header="Dim Grid">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Chọn điểm trên view để tự động đo kích thước Grid." 
                               TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                    
                    <Button Grid.Row="1" Content="Pick Point" Width="120" Height="40" Click="BtnPickPointGrid_Click" 
                            Style="{StaticResource ActionButton}"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Dim Wall -->
            <TabItem Header="Dim Wall">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Chọn Tường trên view để tự động đo kích thước (3 lớp)." 
                               TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                    
                    <Button Grid.Row="1" Content="Pick Wall" Width="120" Height="40" Click="BtnPickPointWall_Click" 
                            Style="{StaticResource ActionButton}"/>
                </Grid>
            </TabItem>
            
            <!-- Tab 3: Dim Multi Walls -->
            <TabItem Header="Dim Multi Walls">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Chọn nhiều bức tường, hoặc kẻ 1 đường cắt qua các tường để tự động Dim (1 lớp)." 
                               TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" TextAlignment="Center"/>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Pick Walls" Width="120" Height="40" Margin="0,0,10,0" Click="BtnPickMultiWallsSelection_Click" 
                                Style="{StaticResource ActionButton}"/>
                        <Button Content="Draw Line" Width="120" Height="40" Click="BtnPickMultiWalls_Click" 
                                Style="{StaticResource ActionButton}" Background="#FF4CAF50"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Tab 4: Setup -->
            <TabItem Header="Setup">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Cài đặt thông số đường Dim:" FontWeight="Bold" Margin="0,0,0,15" />
                    
                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Loại đường Dim (Dimension Type):" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding DimensionTypes}" SelectedItem="{Binding SelectedDimensionType, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Khoảng cách tới Dim gần nhất (0 = dùng điểm click):" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding DistanceToNearestDim, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" TextAlignment="Right" Padding="4"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Khoảng cách giữa các lớp Dim:" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding DistanceBetweenDims, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" TextAlignment="Right" Padding="4"/>
                    </Grid>

                    <StackPanel Grid.Row="4" Margin="0,20,0,0">
                        <TextBlock Text="Tùy chọn ghi kích thước Cửa (áp dụng cho Dim Wall):" FontWeight="Bold" Margin="0,0,0,10" />
                        <RadioButton Content="Dim vào 2 mép cửa (Openings/Widths)" IsChecked="{Binding DimOpenings}" Margin="0,0,0,5" />
                        <RadioButton Content="Dim vào tâm cửa (Centers)" IsChecked="{Binding DimCenters}" Margin="0,0,0,5" />
                    </StackPanel>

                    <CheckBox Grid.Row="5" Content="Tạo đường Dim tổng" IsChecked="{Binding DimOverall}" Margin="0,15,0,0" FontWeight="Bold"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
