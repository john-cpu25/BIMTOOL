<Window x:Class="RincoNhan.Tools.TwoDFamilyManager.UI.FamilyManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RincoNhan.Tools.TwoDFamilyManager.Models"
        Title="2D Family Manager" Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        Background="#F5F7F9">
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#2E5C9A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F4678"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type models:FamilyCategoryItem}" ItemsSource="{Binding Families}">
            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#2C3E50" Margin="0,2"/>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type models:FamilyModelItem}" ItemsSource="{Binding Symbols}">
            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#34495E" Margin="0,2"/>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type models:FamilySymbolItem}">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <Image Source="{Binding Image}" Width="32" Height="32" Margin="0,0,5,0" Stretch="Uniform" VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <TextBlock Text="{Binding Name}" Foreground="#7F8C8D" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Search:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0" Foreground="#2C3E50"/>
            <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
        </Grid>

        <!-- Tree View -->
        <TreeView Grid.Row="1" ItemsSource="{Binding Categories}" BorderBrush="#DCDDE1" Padding="5" x:Name="FamilyTreeView" SelectedItemChanged="FamilyTreeView_SelectedItemChanged">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Expand All" Click="ExpandAll_Click"/>
                    <MenuItem Header="Collapse Selected" Click="CollapseSelected_Click"/>
                    <MenuItem Header="Collapse All" Click="CollapseAll_Click"/>
                </ContextMenu>
            </TreeView.ContextMenu>
            <TreeView.ItemContainerStyle>
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- Bottom Buttons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0" Padding="10,10,0,0" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Place" Command="{Binding PlaceCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="100" Margin="0,0,10,0"/>
                <Button Content="Close" Click="CloseButton_Click" Style="{StaticResource PrimaryButtonStyle}" Background="#95A5A6" Width="80"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
