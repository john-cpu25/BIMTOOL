<Window x:Class="RincoNhan.Tools.Align_Dim.UI.AlignDimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RincoNhan.Tools.Align_Dim.UI"
        xmlns:viewmodels="clr-namespace:RincoNhan.Tools.Align_Dim.ViewModels"
        mc:Ignorable="d"
        Title="Align Dimension" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Topmost="True" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex}" Margin="0,0,0,10">
            <!-- Tab 1: By Distance -->
            <TabItem Header="By Distance" Padding="10,5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Distance from Grid (mm):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="1" Text="{Binding Distance, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="5" Height="25" VerticalContentAlignment="Center"/>

                    <CheckBox Grid.Row="2" Content="Save as Template (Remember distance)" 
                              IsChecked="{Binding SaveTemplate}" 
                              VerticalAlignment="Center" Margin="0,15,0,0"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Match Views -->
            <TabItem Header="Match Views" Padding="10,5">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Source View: " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SourceViewName}" Foreground="#007ACC" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Select Target Views:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
                        <Button Content="Select All" Command="{Binding SelectAllViewsCommand}" 
                                Background="Transparent" BorderThickness="0" Foreground="#007ACC" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button Content="Select None" Command="{Binding SelectNoneViewsCommand}" 
                                Background="Transparent" BorderThickness="0" Foreground="#007ACC" Cursor="Hand"/>
                    </StackPanel>

                    <Border Grid.Row="3" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="3">
                        <ListBox ItemsSource="{Binding TargetViews}" BorderThickness="0" 
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding ViewName}" IsChecked="{Binding IsSelected}" Margin="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="Pick &amp; Align" Command="{Binding ApplyCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            
            <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="35" Background="#E0E0E0" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
