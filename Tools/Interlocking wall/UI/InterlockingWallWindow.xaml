<Window x:Class="RincoNhan.Tools.InterlockingWall.UI.InterlockingWallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interlocking Wall Tool" Height="620" Width="750"
        WindowStartupLocation="CenterScreen" Background="#FFFFFF"
        Foreground="#1F2937" FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Button Style for Equal/Custom -->
        <Style x:Key="ToggleRadio" TargetType="RadioButton">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#F3F4F6" CornerRadius="5" Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="#E5E7EB">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="INTERLOCKING WALL" FontSize="22" FontWeight="Bold" Foreground="#1E3A8A"/>
            <TextBlock Text="Merge walls together or split a wall panel into multiple segments." Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Content: TabControl -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="0,0,0,3" Margin="0,0,10,10">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB"/>
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ==================== Tab 1: MERGE WALLS ==================== -->
            <TabItem Header="🔗 MERGE WALLS">
                <Border Background="#F0FDF4" CornerRadius="8" Padding="20" BorderBrush="#DCFCE7" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="MERGE TWO WALLS" FontWeight="Bold" FontSize="14" Foreground="#166534" Margin="0,0,0,5"/>
                        <TextBlock Text="Select 2 walls in Revit to merge them into one wall." FontSize="12" Foreground="#15803D" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Pick Button -->
                        <Button Command="{Binding PickTwoWallsCommand}" Style="{StaticResource SecondaryButton}" 
                                Content="🧱 Pick 2 Walls" Height="40" Margin="0,0,0,20" FontWeight="SemiBold"/>

                        <!-- Wall Info Cards -->
                        <Border Background="White" CornerRadius="6" Padding="15" BorderBrush="#DCFCE7" BorderThickness="1" Margin="0,0,0,10"
                                Visibility="{Binding HasTwoWalls, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- Wall 1 -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="WALL 1" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📐 " FontSize="14"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Wall1Name}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding Wall1IdText, StringFormat=ID: {0}}" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,12"/>

                                <!-- Wall 2 -->
                                <StackPanel>
                                    <TextBlock Text="WALL 2" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📐 " FontSize="14"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Wall2Name}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding Wall2IdText, StringFormat=ID: {0}}" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Empty State -->
                        <Border Background="White" CornerRadius="6" Padding="20" BorderBrush="#DCFCE7" BorderThickness="1" Margin="0,0,0,20">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTwoWalls}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🧱" FontSize="28" HorizontalAlignment="Center" Foreground="#CBD5E1"/>
                                <TextBlock Text="No walls selected yet" Foreground="#94A3B8" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Merge Button -->
                        <Button Command="{Binding JoinWallsCommand}" IsEnabled="{Binding HasTwoWalls}" Height="45"
                                Background="#10B981" Style="{StaticResource ActionButton}" Content="✓ Merge Walls"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ==================== Tab 2: SPLIT WALL ==================== -->
            <TabItem Header="✂ SPLIT WALL">
                <Border Background="#FFF7ED" CornerRadius="8" Padding="15" BorderBrush="#FFEDD5" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Controls -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SPLIT WALL PANEL" FontWeight="Bold" FontSize="14" Foreground="#9A3412" Margin="0,0,0,5"/>
                            <TextBlock Text="Split a wall into multiple segments." FontSize="11" Foreground="#C2410C" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <!-- Pick Button -->
                            <Button Command="{Binding PickWallToSplitCommand}" Style="{StaticResource SecondaryButton}" 
                                    Content="🔍 Pick Wall Panel" Height="36" Margin="0,0,0,12" FontWeight="SemiBold"/>

                            <!-- Wall Info -->
                            <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#FFEDD5" BorderThickness="1" Margin="0,0,0,12"
                                    Visibility="{Binding HasWallToSplit, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="SELECTED WALL" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SelectedWallName}" FontWeight="Bold" Foreground="#1E293B" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding SelectedWallIdText, StringFormat=ID: {0}}" FontSize="10" Foreground="#64748B" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding WallLengthMm, StringFormat={}{0:F0}mm}" FontSize="10" Foreground="#64748B"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Number of Panels -->
                            <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#FFEDD5" BorderThickness="1" Margin="0,0,0,12"
                                    Visibility="{Binding HasWallToSplit, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="NUMBER OF PANELS" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Split into:" VerticalAlignment="Center" FontSize="12" Foreground="#374151" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding PanelCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" FontWeight="Bold" Foreground="#9A3412" 
                                                 Padding="8,5" BorderBrush="#FFEDD5" BorderThickness="1"
                                                 HorizontalContentAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Split Mode Toggle -->
                            <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#FFEDD5" BorderThickness="1" Margin="0,0,0,12"
                                    Visibility="{Binding HasWallToSplit, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="SPLIT MODE" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0" Content="Equal" GroupName="SplitMode" 
                                                     IsChecked="{Binding IsEqualSplit, Mode=TwoWay}" Style="{StaticResource ToggleRadio}"/>
                                        <RadioButton x:Name="CustomRadio" Grid.Column="2" Content="Custom" GroupName="SplitMode" 
                                                     Style="{StaticResource ToggleRadio}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Segment Lengths (Custom Mode) -->
                            <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#FFEDD5" BorderThickness="1" Margin="0,0,0,12"
                                    Visibility="{Binding HasWallToSplit, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="PANEL LENGTHS (mm)" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding Segments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="55"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11" Foreground="#64748B">
                                                        <TextBlock.Text>
                                                            <Binding Path="Index" StringFormat="Panel {0}:"/>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBox Grid.Column="1" Text="{Binding LengthMm, StringFormat={}{0:F0}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                             FontSize="12" FontWeight="SemiBold" Foreground="#9A3412"
                                                             Padding="6,3" BorderBrush="#FFEDD5" BorderThickness="1"
                                                             IsReadOnly="{Binding DataContext.IsEqualSplit, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             HorizontalContentAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Split Button -->
                            <Button Command="{Binding SplitWallCommand}" IsEnabled="{Binding HasWallToSplit}" Height="42"
                                    Background="#F59E0B" Style="{StaticResource ActionButton}" Content="✂ Split &amp; Disjoin"/>

                            <!-- Empty State -->
                            <Border Background="White" CornerRadius="6" Padding="25" BorderBrush="#FFEDD5" BorderThickness="1" Margin="0,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasWallToSplit}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="✂" FontSize="28" HorizontalAlignment="Center" Foreground="#CBD5E1"/>
                                    <TextBlock Text="Pick a wall panel to get started" Foreground="#94A3B8" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- RIGHT: Visual Preview -->
                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#FFEDD5" BorderThickness="1"
                                Visibility="{Binding HasWallToSplit, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="PREVIEW" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                
                                <!-- Direction labels (swap based on wall direction) -->
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding LeftLabel, StringFormat=◀ {0}}" FontSize="10" FontWeight="Bold" Foreground="#16A34A"/>
                                        <TextBlock Text="{Binding LeftCoord}" FontSize="9" Foreground="#64748B"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="─── Panel 1 → N ───▶" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               FontSize="9" Foreground="#94A3B8"/>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding RightLabel, StringFormat={}{0} ▶}" FontSize="10" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding RightCoord}" FontSize="9" Foreground="#64748B" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Wall total length -->
                                <TextBlock DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="0,8,0,0"
                                           FontSize="12" FontWeight="Bold" Foreground="#374151"
                                           Text="{Binding WallLengthMm, StringFormat=Total: {0:F0}mm}"/>

                                <!-- Segments Visual (FlowDirection reverses for right-to-left walls) -->
                                <Border CornerRadius="4" ClipToBounds="True" BorderBrush="#93C5FD" BorderThickness="2">
                                    <ItemsControl ItemsSource="{Binding Segments}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="FlowDirection" Value="LeftToRight"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWallReversed}" Value="True">
                                                        <Setter Property="FlowDirection" Value="RightToLeft"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#94A3B8" BorderThickness="0,0,1,0" Background="#DBEAFE"
                                                        Width="{Binding PreviewWidth}" MinWidth="40">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Foreground="#1E40AF">
                                                            <TextBlock.Text>
                                                                <Binding Path="Index" StringFormat="Panel {0}"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12" Foreground="#9A3412">
                                                            <TextBlock.Text>
                                                                <Binding Path="LengthMm" StringFormat="{}{0:F0}mm"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ==================== Tab 3: GROUP WALL ==================== -->
            <TabItem Header="📦 GROUP WALL">
                <Border Background="#F5F3FF" CornerRadius="8" Padding="15" BorderBrush="#EDE9FE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Controls -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="GROUP WALL SPLIT" FontWeight="Bold" FontSize="14" Foreground="#5B21B6" Margin="0,0,0,5"/>
                                <TextBlock Text="Select a group of 4 walls. Walls 3 (bottom) and 4 (top) will be split." FontSize="11" Foreground="#7C3AED" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <!-- Pick Group Button -->
                                <Button Command="{Binding PickGroupCommand}" Style="{StaticResource SecondaryButton}" 
                                        Content="📦 Pick Group" Height="36" Margin="0,0,0,12" FontWeight="SemiBold"/>

                                <!-- Group Info -->
                                <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#EDE9FE" BorderThickness="1" Margin="0,0,0,10"
                                        Visibility="{Binding HasGroupSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="SELECTED GROUP" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding GroupName}" FontWeight="Bold" Foreground="#1E293B" FontSize="12"/>
                                        <TextBlock Text="{Binding GroupIdText, StringFormat=ID: {0}}" FontSize="10" Foreground="#64748B"/>
                                    </StackPanel>
                                </Border>

                                <!-- 4 Wall Info Cards -->
                                <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#EDE9FE" BorderThickness="1" Margin="0,0,0,10"
                                        Visibility="{Binding HasGroupSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="WALLS IN GROUP" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                        
                                        <!-- Wall 1 - Keep -->
                                        <Border Background="#F0FDF4" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="#16A34A" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding GroupWall1Info}" FontSize="10" Foreground="#15803D" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Wall 2 - Keep -->
                                        <Border Background="#F0FDF4" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓ " Foreground="#16A34A" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding GroupWall2Info}" FontSize="10" Foreground="#15803D" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Wall 3 - Will Split -->
                                        <Border Background="#FFF7ED" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✂ " Foreground="#EA580C" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding GroupWall3Info}" FontSize="10" Foreground="#C2410C" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Wall 4 - Will Split -->
                                        <Border Background="#FFF7ED" CornerRadius="4" Padding="6" Margin="0,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✂ " Foreground="#EA580C" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding GroupWall4Info}" FontSize="10" Foreground="#C2410C" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Wall 3 Split Settings -->
                                <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#FFEDD5" BorderThickness="1" Margin="0,0,0,8"
                                        Visibility="{Binding HasGroupSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="WALL 3 (BOTTOM) - SPLIT" FontSize="9" FontWeight="Bold" Foreground="#EA580C" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Panels:" VerticalAlignment="Center" FontSize="11" Foreground="#374151" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Wall3PanelCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontSize="13" FontWeight="Bold" Foreground="#9A3412" 
                                                     Padding="6,4" BorderBrush="#FFEDD5" BorderThickness="1"
                                                     HorizontalContentAlignment="Center"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Wall3Segments}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="10" Foreground="#64748B">
                                                            <TextBlock.Text>
                                                                <Binding Path="Index" StringFormat="P{0}:"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBox Grid.Column="1" Text="{Binding LengthMm, StringFormat={}{0:F0}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                 FontSize="11" FontWeight="SemiBold" Foreground="#9A3412"
                                                                 Padding="4,2" BorderBrush="#FFEDD5" BorderThickness="1"
                                                                 HorizontalContentAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Wall 4 Split Settings -->
                                <Border Background="White" CornerRadius="6" Padding="10" BorderBrush="#DBEAFE" BorderThickness="1" Margin="0,0,0,10"
                                        Visibility="{Binding HasGroupSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="WALL 4 (TOP) - SPLIT" FontSize="9" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Panels:" VerticalAlignment="Center" FontSize="11" Foreground="#374151" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Wall4PanelCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontSize="13" FontWeight="Bold" Foreground="#1E40AF" 
                                                     Padding="6,4" BorderBrush="#DBEAFE" BorderThickness="1"
                                                     HorizontalContentAlignment="Center"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Wall4Segments}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="10" Foreground="#64748B">
                                                            <TextBlock.Text>
                                                                <Binding Path="Index" StringFormat="P{0}:"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBox Grid.Column="1" Text="{Binding LengthMm, StringFormat={}{0:F0}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                 FontSize="11" FontWeight="SemiBold" Foreground="#1E40AF"
                                                                 Padding="4,2" BorderBrush="#DBEAFE" BorderThickness="1"
                                                                 HorizontalContentAlignment="Right"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Execute Button -->
                                <Button Command="{Binding ExecuteGroupCommand}" IsEnabled="{Binding HasGroupSelected}" Height="42"
                                        Background="#7C3AED" Style="{StaticResource ActionButton}" Content="⚡ Execute Group Split"/>

                                <!-- Empty State -->
                                <Border Background="White" CornerRadius="6" Padding="25" BorderBrush="#EDE9FE" BorderThickness="1" Margin="0,12,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasGroupSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📦" FontSize="28" HorizontalAlignment="Center" Foreground="#CBD5E1"/>
                                        <TextBlock Text="Pick a group to get started" Foreground="#94A3B8" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT: Visual Preview -->
                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" BorderBrush="#EDE9FE" BorderThickness="1"
                                Visibility="{Binding HasGroupSelected, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="GROUP PREVIEW" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,10"/>
                                
                                <!-- Rectangle visualization of 4 walls with corner overlaps -->
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!-- Wall 4 label -->
                                        <RowDefinition Height="Auto"/>  <!-- Wall 4 + corners -->
                                        <RowDefinition Height="120"/>   <!-- Middle -->
                                        <RowDefinition Height="Auto"/>  <!-- Wall 3 + corners -->
                                        <RowDefinition Height="Auto"/>  <!-- Wall 3 label -->
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>  <!-- W1 -->
                                        <ColumnDefinition Width="*"/>   <!-- Center -->
                                        <ColumnDefinition Width="28"/>  <!-- W2 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Wall 4 Label -->
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Wall 4 (Top) ✂" HorizontalAlignment="Center" 
                                               FontSize="10" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,4"/>

                                    <!-- === ROW 1: Wall 4 (Top) with corner overlaps === -->
                                    <!-- W1 corner overlap (top-left) -->
                                    <Border Grid.Row="1" Grid.Column="0" Background="#22C55E" BorderBrush="#166534" BorderThickness="2" Height="28" CornerRadius="0"/>
                                    
                                    <!-- Wall 4 segments (center) -->
                                    <Border Grid.Row="1" Grid.Column="1" ClipToBounds="True" BorderBrush="#2563EB" BorderThickness="0,2" Height="28">
                                        <ItemsControl ItemsSource="{Binding Wall4Segments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#60A5FA" BorderThickness="0,0,1,0" Background="#DBEAFE"
                                                            Width="{Binding PreviewWidth}" MinWidth="30">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="9" FontWeight="Bold" Foreground="#1E40AF"
                                                                   Text="{Binding LengthMm, StringFormat={}{0:F0}}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- W2 corner overlap (top-right) -->
                                    <Border Grid.Row="1" Grid.Column="2" Background="#22C55E" BorderBrush="#166534" BorderThickness="2" Height="28" CornerRadius="0"/>

                                    <!-- === ROW 2: Middle - W1 left, empty center, W2 right === -->
                                    <!-- Wall 1 - Left (full height) -->
                                    <Border Grid.Row="2" Grid.Column="0" Background="#BBF7D0" BorderBrush="#22C55E" BorderThickness="2,0">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="W" FontSize="10" FontWeight="Bold" Foreground="#166534" HorizontalAlignment="Center"/>
                                            <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="#166534" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Center empty space -->
                                    <Border Grid.Row="2" Grid.Column="1" Background="#FAFAF9">
                                        <TextBlock Text="GROUP" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="16" FontWeight="Bold" Foreground="#D4D4D8" Opacity="0.5"/>
                                    </Border>

                                    <!-- Wall 2 - Right (full height) -->
                                    <Border Grid.Row="2" Grid.Column="2" Background="#BBF7D0" BorderBrush="#22C55E" BorderThickness="2,0">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="W" FontSize="10" FontWeight="Bold" Foreground="#166534" HorizontalAlignment="Center"/>
                                            <TextBlock Text="2" FontSize="10" FontWeight="Bold" Foreground="#166534" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- === ROW 3: Wall 3 (Bottom) with corner overlaps === -->
                                    <!-- W1 corner overlap (bottom-left) -->
                                    <Border Grid.Row="3" Grid.Column="0" Background="#22C55E" BorderBrush="#166534" BorderThickness="2" Height="28" CornerRadius="0"/>

                                    <!-- Wall 3 segments (center) -->
                                    <Border Grid.Row="3" Grid.Column="1" ClipToBounds="True" BorderBrush="#EA580C" BorderThickness="0,2" Height="28">
                                        <ItemsControl ItemsSource="{Binding Wall3Segments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#FB923C" BorderThickness="0,0,1,0" Background="#FED7AA"
                                                            Width="{Binding PreviewWidth}" MinWidth="30">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="9" FontWeight="Bold" Foreground="#9A3412"
                                                                   Text="{Binding LengthMm, StringFormat={}{0:F0}}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- W2 corner overlap (bottom-right) -->
                                    <Border Grid.Row="3" Grid.Column="2" Background="#22C55E" BorderBrush="#166534" BorderThickness="2" Height="28" CornerRadius="0"/>

                                    <!-- Wall 3 Label -->
                                    <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="Wall 3 (Bottom) ✂" HorizontalAlignment="Center" 
                                               FontSize="10" FontWeight="Bold" Foreground="#EA580C" Margin="0,4,0,0"/>
                                </Grid>

                                <!-- Legend -->
                                <!-- (legend removed to keep preview clean) -->
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Margin="0,10,0,0" Padding="10" Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="6"
                Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ" Foreground="#0284C7" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#0369A1" FontWeight="Medium" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
