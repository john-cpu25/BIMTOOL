<Window x:Class="RincoNhan.Tools.SmartLinkRevit.SmartLinkRevitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Link Revit - Display Settings" Height="650" Width="600"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#F5F5F5">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Host Views Section -->
        <GroupBox Grid.Row="0" Header="1. Select Host Views" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <TextBlock Text="Filter by View Type:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cboViewType" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25" SelectionChanged="CboViewType_SelectionChanged"/>
                
                <Grid Margin="0,10,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Host Views:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox x:Name="chkSelectAllViews" Grid.Column="1" Content="Select All" Click="ChkSelectAllViews_Click" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Host Views List -->
        <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" Background="White" Margin="0,0,0,10">
            <ListView x:Name="lstHostViews" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="2"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Revit Link Settings -->
        <GroupBox Grid.Row="2" Header="2. Revit Link Display Settings" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Select Link -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Revit Link:" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <ComboBox x:Name="cboLinks" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Name" Height="25" Margin="0,0,0,10" SelectionChanged="CboLinks_SelectionChanged"/>

                <!-- Display Type -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Display Type:" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton x:Name="optHostView" Content="By host view" Margin="0,0,15,0" Checked="DisplayType_Changed"/>
                    <RadioButton x:Name="optLinkedView" Content="By linked view" Margin="0,0,15,0" Checked="DisplayType_Changed"/>
                    <RadioButton x:Name="optCustom" Content="Custom" IsChecked="True" Checked="DisplayType_Changed"/>
                </StackPanel>

                <!-- Linked View Selection -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Linked View:" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <ComboBox x:Name="cboLinkedViews" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Name" Height="25" Margin="0,0,0,10"/>

            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <Grid Grid.Row="3" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" Content="Apply" Width="100" Height="30" Margin="0,0,10,0" Click="BtnApply_Click" Background="#0078D7" Foreground="White" FontWeight="Bold"/>
            <Button Grid.Column="2" Content="Close" Width="80" Height="30" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
