<Window x:Class="RincoNhan.Tools.AutoPT.AutoPTWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto PT from CAD Settings" Height="250" Width="350"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="CAD Link Layer:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox Name="cmbLayers" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Default High Point (mm):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="txtHighPoint" Grid.Row="1" Grid.Column="1" Margin="5" Text="150"/>

        <TextBlock Text="Default Low Point (mm):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="txtLowPoint" Grid.Row="2" Grid.Column="1" Margin="5" Text="0"/>

        <TextBlock Text="Chair Max Spacing (mm):" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="txtChairSpacing" Grid.Row="3" Grid.Column="1" Margin="5" Text="1000"/>
        
        <TextBlock Name="txtStatus" Grid.Row="4" Grid.ColumnSpan="2" Margin="5" Foreground="Gray" FontStyle="Italic"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Generate" Width="80" Margin="5" Click="BtnGenerate_Click"/>
            <Button Content="Cancel" Width="80" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
