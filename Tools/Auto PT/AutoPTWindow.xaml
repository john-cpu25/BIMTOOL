<Window x:Class="RincoNhan.Tools.AutoPT.AutoPTWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto PT from CAD Settings" Height="320" Width="380"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Selected Layer:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBlock Name="txtSelectedLayer" Grid.Column="1" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>
        </Grid>

        <GroupBox Header="Tùy chọn Cáp PT" Grid.Row="1" Margin="0,5">
            <Grid Margin="10">
                <CheckBox Name="chkGeneratePTRinco" Content="Tạo family PT [Rinco] (Dây cáp)" IsChecked="True" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Generate" Width="80" Margin="5" Click="BtnGenerate_Click"/>
            <Button Content="Cancel" Width="80" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
