<Window x:Class="RincoNhan.Tools.MtoGroupBar.UI.MtoGroupBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MTO Group Bar" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Lapped Rebar Groups" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <Button Grid.Row="1" Content="Random Colors (Override Graphics)" Margin="0,0,0,10" Height="30" Click="BtnRandomColors_Click"/>

        <DataGrid Grid.Row="2" x:Name="DataGridGroups" AutoGenerateColumns="False" 
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" AlternatingRowBackground="#FFF0F0F0"
                  GridLinesVisibility="All" BorderBrush="#FFCCCCCC" BorderThickness="1"
                  SelectionMode="Single" SelectionChanged="DataGridGroups_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Group Name" Binding="{Binding GroupName}" Width="*"/>
                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80"/>
                <DataGridTemplateColumn Header="Color" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding DisplayColor}" BorderBrush="Black" BorderThickness="1" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Width="100" Height="30" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
