<Window x:Class="RincoNhan.Tools.AddSharedParameters.UI.AddSharedParamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Shared Parameters" Height="550" Width="500"
        WindowStartupLocation="CenterScreen"
        Topmost="True" x:Name="window">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select Shared Parameters to Add" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="Blue" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <ListView Grid.Row="2" ItemsSource="{Binding Parameters}" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.Header>
                            <CheckBox IsChecked="{Binding DataContext.AllSelected, RelativeSource={RelativeSource AncestorType=Window}}" 
                                      ToolTip="Select/Deselect All"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="Group" DisplayMemberBinding="{Binding GroupName}" Width="100"/>
                    <GridViewColumn Header="DataType" DisplayMemberBinding="{Binding DataType}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Select All" Command="{Binding SelectAllCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="Select None" Command="{Binding SelectNoneCommand}" Width="80"/>
        </StackPanel>

        <Grid Grid.Row="4" Background="#FFF5F5F5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="10">
                <TextBlock Text="Parameter Type:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton Content="Type" IsChecked="{Binding IsType}" Margin="0,0,0,5"/>
                <RadioButton Content="Instance" IsChecked="{Binding IsInstance}"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="10">
                <TextBlock Text="Group parameter under:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding ParameterGroups}" SelectedItem="{Binding SelectedGroup}" Width="150" HorizontalAlignment="Left"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10" VerticalAlignment="Bottom">
                <Button Content="Add Parameters" Command="{Binding AddParametersCommand}" CommandParameter="{Binding ElementName=window}" 
                        Width="120" Height="30" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button Content="Cancel" Click="Cancel_Click" Width="70" Height="30"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
