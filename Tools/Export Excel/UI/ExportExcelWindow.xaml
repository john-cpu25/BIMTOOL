<Window x:Class="RincoNhan.Tools.ExportExcel.UI.ExportExcelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RincoNhan.Tools.ExportExcel.UI"
        mc:Ignorable="d"
        Title="Export Schedules to Excel" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="Select All" IsChecked="{Binding SelectAll}" FontWeight="Bold" VerticalAlignment="Center"/>
            <CheckBox Content="Export as individual files" IsChecked="{Binding ExportAsIndividualFiles}" Margin="20,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="Format:" VerticalAlignment="Center" Margin="20,0,5,0" />
            <ComboBox SelectedValue="{Binding SelectedFormat}" SelectedValuePath="Content" VerticalAlignment="Center" Width="80">
                <ComboBoxItem Content="XLSX" IsSelected="True"/>
                <ComboBoxItem Content="CSV"/>
            </ComboBox>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Schedules}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header=" " Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
                <DataGridTextColumn Header="Schedule Name" Binding="{Binding Name}" IsReadOnly="True" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontStyle="Italic"/>
            <Button Grid.Column="1" Content="Export to Excel" Command="{Binding ExportCommand}" Width="120" Height="30" Padding="5"/>
        </Grid>
    </Grid>
</Window>
