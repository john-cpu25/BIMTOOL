<Window x:Class="RincoNhan.Tools.Create_Sheet_Set.UI.CreateSheetSetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Revision Sheet Set" Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select Revisions:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ListBox x:Name="lbRevisions" Grid.Row="1" Margin="0,0,0,10" SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Match Options:" FontWeight="Bold" Grid.Row="2" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="rbMatchAny" Content="Matching ANY revision" IsChecked="False" Margin="0,0,10,0" IsEnabled="False"/>
            <RadioButton x:Name="rbMatchAll" Content="Matching ALL revisions" IsChecked="True" IsEnabled="False"/>
        </StackPanel>

        <TextBlock Text="Enter a name for the new revision sheet set:" FontWeight="Bold" Grid.Row="4" Margin="0,0,0,5"/>
        <TextBox x:Name="txtSetName" Grid.Row="5" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create" Width="80" Height="25" Margin="0,0,10,0" Click="BtnCreate_Click"/>
            <Button Content="Cancel" Width="80" Height="25" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
