<Window x:Class="RincoNhan.Tools.SmartLinkCad.SmartLinkCadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Link CAD - Override Graphics" 
        Height="650" Width="950"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#F5F7FA"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgHover" Color="#EEF0F5"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4F6AF0"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>

        <!-- Modern Button -->
        <Style x:Key="ModernBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ModernBtn}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Orange Button -->
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource ModernBtn}">
            <Setter Property="Background" Value="{StaticResource AccentOrange}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ListView Item -->
        <Style x:Key="ListItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="1">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GridView ListView Item -->
        <Style x:Key="GridListItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="1">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6,6,0,0" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Smart Link CAD" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="View Template:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <ComboBox x:Name="cboViewTemplates" Width="300" Height="26" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="12,8,12,0">

            <!-- ═══════════ TAB 1: Batch Override ═══════════ -->
            <TabItem Header="📋 Batch Override">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Settings -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="14" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Override Settings" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,12"/>

                            <TextBlock Text="Line Color" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border x:Name="brdColor" Width="50" Height="26" CornerRadius="4" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="#50C896"/>
                                <Button Content="Pick" Style="{StaticResource ModernBtn}" Margin="8,0,0,0" Padding="10,4" Click="BtnPickColor_Click"/>
                            </StackPanel>

                            <CheckBox x:Name="chkHalftone" Content="Halftone" Margin="0,0,0,12"/>

                            <TextBlock Text="Line Weight" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cboWeight" Height="26" Margin="0,0,0,12"/>

                            <TextBlock Text="Line Pattern" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cboPattern" Height="26" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,16"/>

                            <Button Content="▶ Apply Override" Style="{StaticResource PrimaryBtn}" Click="BtnApply_Click" Padding="14,8"/>
                        </StackPanel>
                    </Border>

                    <!-- RIGHT: CAD File List -->
                    <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="14,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="Select CAD Files" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    <Button Content="Select All" Style="{StaticResource ModernBtn}" HorizontalAlignment="Right" Padding="10,4" FontSize="11" Click="BtnSelectAll_Click"/>
                                </Grid>
                            </Border>

                            <ListView Grid.Row="1" x:Name="lstCadFiles" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource ListItem}" Margin="4">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="6,2" FontSize="12"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════ TAB 2: Layer Management ═══════════ -->
            <TabItem Header="🔧 Layer Management">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Filters + Settings -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- CAD File Filter -->
                            <Border Background="White" CornerRadius="8" Padding="14" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Filter by CAD File" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="All" Style="{StaticResource ModernBtn}" Padding="8,2" FontSize="10" Margin="0,0,4,0" Click="BtnCadFilterAll_Click"/>
                                            <Button Content="None" Style="{StaticResource ModernBtn}" Padding="8,2" FontSize="10" Click="BtnCadFilterNone_Click"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="{StaticResource BgPrimary}" CornerRadius="4" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" MaxHeight="120">
                                        <ListBox x:Name="lstCadFilter" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="4,2" FontSize="11" Click="ChkCadFilter_Click"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Search -->
                            <Border Background="White" CornerRadius="8" Padding="14" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="🔍 Search Layer" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtLayerFilter" Height="28" VerticalContentAlignment="Center" Background="{StaticResource BgPrimary}" BorderBrush="{StaticResource BorderColor}" Foreground="{StaticResource TextPrimary}" Padding="6,4" TextChanged="TxtLayerFilter_TextChanged"/>
                                        <Button Grid.Column="1" Content="✕" Style="{StaticResource ModernBtn}" Padding="8,2" Margin="6,0,0,0" Click="BtnClearFilter_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="txtLayerCount" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Presets -->
                            <Border Background="White" CornerRadius="8" Padding="14" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="📁 Visibility Presets" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentGreen}" Margin="0,0,0,8"/>
                                    
                                    <!-- Preset selector -->
                                    <ComboBox x:Name="cboPresets" Height="26" DisplayMemberPath="Name" Margin="0,0,0,8" SelectionChanged="CboPresets_SelectionChanged"/>
                                    
                                    <!-- Preset name input -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtPresetName" Height="28" VerticalContentAlignment="Center" 
                                                 Background="{StaticResource BgPrimary}" BorderBrush="{StaticResource BorderColor}" 
                                                 Foreground="{StaticResource TextPrimary}" Padding="6,4"/>
                                        <Button Grid.Column="1" Content="💾 Save" Style="{StaticResource ModernBtn}" 
                                                Padding="10,4" Margin="6,0,0,0" FontSize="11" Click="BtnSavePreset_Click"/>
                                    </Grid>
                                    
                                    <!-- Load / Delete -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="📂 Load" Style="{StaticResource ModernBtn}" 
                                                Padding="8,4" FontSize="11" Margin="0,0,4,0" Click="BtnLoadPreset_Click"/>
                                        <Button Grid.Column="1" Content="🗑 Delete" Style="{StaticResource ModernBtn}" 
                                                Padding="8,4" FontSize="11" Margin="4,0,0,0" Click="BtnDeletePreset_Click"/>
                                    </Grid>

                                    <TextBlock x:Name="txtPresetInfo" FontSize="10" Foreground="{StaticResource TextSecondary}" 
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Layer Override Settings -->
                            <Border Background="White" CornerRadius="8" Padding="14" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Layer Override" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentOrange}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Color" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border x:Name="brdLayerColor" Width="50" Height="26" CornerRadius="4" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="#50C896"/>
                                        <Button Content="Pick" Style="{StaticResource ModernBtn}" Margin="8,0,0,0" Padding="10,4" Click="BtnPickLayerColor_Click"/>
                                    </StackPanel>

                                    <CheckBox x:Name="chkLayerHalftone" Content="Halftone" Margin="0,0,0,10"/>

                                    <TextBlock Text="Weight" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cboLayerWeight" Height="26" Margin="0,0,0,10"/>

                                    <TextBlock Text="Pattern" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cboLayerPattern" Height="26" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,14"/>

                                    <Button Content="👁 Apply Visibility" Style="{StaticResource PrimaryBtn}" Padding="14,8" Margin="0,0,0,8" Click="BtnApplyVisibility_Click"/>
                                    <Button Content="🎨 Apply Override" Style="{StaticResource OrangeBtn}" Padding="14,8" Click="BtnApplyLayerOverride_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- RIGHT: Layer List -->
                    <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="14,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <TextBlock Text="Layers" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                            </Border>

                            <ListView Grid.Row="1" x:Name="lstLayers" Background="Transparent" BorderThickness="0"
                                      ItemContainerStyle="{StaticResource GridListItem}" Margin="4">
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="GridViewColumnHeader">
                                                <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>

                                        <GridViewColumn Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="Toggle visibility"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                            <GridViewColumn.Header>
                                                <CheckBox x:Name="chkSelectAllLayers" ToolTip="Select/Deselect all" Click="ChkSelectAllLayers_Click"/>
                                            </GridViewColumn.Header>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Layer Name" Width="250" DisplayMemberBinding="{Binding LayerName}"/>
                                        <GridViewColumn Header="CAD File" Width="200" DisplayMemberBinding="{Binding CadFileName}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom -->
        <Border Grid.Row="2" Padding="16,10" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                <Button Content="Close" Style="{StaticResource ModernBtn}" HorizontalAlignment="Right" Width="90" Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
