<Window x:Class="RincoNhan.Tools.SmartLinkCad.SmartLinkCadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart Link Cad - Override Graphics" Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- View Template Selection (shared across tabs) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Select View Template:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cboViewTemplates" DisplayMemberPath="Name" SelectedValuePath="Id" Height="25"/>
        </StackPanel>

        <!-- TabControl -->
        <TabControl Grid.Row="1">

            <!-- ═══════════ TAB 1: Batch Override ═══════════ -->
            <TabItem Header="Batch Override">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Overrides Settings -->
                    <GroupBox Grid.Row="0" Header="Overrides Settings" Margin="0,0,0,10">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Color -->
                            <TextBlock Text="Line Color:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,5">
                                <Border x:Name="brdColor" Width="40" Height="22" BorderBrush="Gray" BorderThickness="1" Background="#50C896"/>
                                <Button Content="..." Width="25" Height="22" Margin="5,0,0,0" Click="BtnPickColor_Click"/>
                            </StackPanel>

                            <!-- Halftone -->
                            <CheckBox x:Name="chkHalftone" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Content="Halftone" VerticalAlignment="Center" Margin="0,0,0,5"/>

                            <!-- Line Weight -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Line Weight:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="cboWeight" Grid.Row="1" Grid.Column="1" Margin="0,0,10,0" Height="22"/>

                            <!-- Line Pattern -->
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Line Pattern:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="cboPattern" Grid.Row="1" Grid.Column="3" DisplayMemberPath="Name" SelectedValuePath="Id" Height="22"/>
                        </Grid>
                    </GroupBox>

                    <!-- CAD List Header -->
                    <TextBlock Grid.Row="1" Text="Select CAD Files to Override:" FontWeight="SemiBold" Margin="0,0,0,5"/>

                    <!-- CAD List -->
                    <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
                        <ListView x:Name="lstCadFiles" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="2"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <!-- Select All -->
                    <Button Grid.Row="3" Content="Select All" HorizontalAlignment="Left" Width="80" Height="25" Margin="0,5,0,0" Click="BtnSelectAll_Click"/>
                </Grid>
            </TabItem>

            <!-- ═══════════ TAB 2: Layer Management ═══════════ -->
            <TabItem Header="Layer Management">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- CAD file filter -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,5">
                        <TextBlock Text="Filter by CAD File:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cboCadFilter" DisplayMemberPath="Name" Height="25" SelectionChanged="CboCadFilter_SelectionChanged"/>
                    </StackPanel>

                    <!-- Per-layer override settings -->
                    <GroupBox Grid.Row="1" Header="Layer Override (for selected layers)" Margin="0,0,0,5">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Color -->
                            <TextBlock Text="Color:" VerticalAlignment="Center" Margin="0,0,5,5"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,5">
                                <Border x:Name="brdLayerColor" Width="40" Height="22" BorderBrush="Gray" BorderThickness="1" Background="#50C896"/>
                                <Button Content="..." Width="25" Height="22" Margin="5,0,0,0" Click="BtnPickLayerColor_Click"/>
                            </StackPanel>

                            <!-- Halftone -->
                            <CheckBox x:Name="chkLayerHalftone" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Content="Halftone" VerticalAlignment="Center" Margin="0,0,0,5"/>

                            <!-- Line Weight -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Weight:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="cboLayerWeight" Grid.Row="1" Grid.Column="1" Margin="0,0,10,0" Height="22"/>

                            <!-- Line Pattern -->
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Pattern:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="cboLayerPattern" Grid.Row="1" Grid.Column="3" DisplayMemberPath="Name" SelectedValuePath="Id" Height="22"/>
                        </Grid>
                    </GroupBox>

                    <!-- Layer list with visibility checkbox -->
                    <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
                        <ListView x:Name="lstLayers" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsVisible}" ToolTip="Toggle visibility"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                        <GridViewColumn.Header>
                                            <CheckBox x:Name="chkSelectAllLayers" Content="" ToolTip="Select/Deselect all" Click="ChkSelectAllLayers_Click"/>
                                        </GridViewColumn.Header>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Layer Name" Width="200" DisplayMemberBinding="{Binding LayerName}"/>
                                    <GridViewColumn Header="CAD File" Width="180" DisplayMemberBinding="{Binding CadFileName}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- Layer action buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Apply Visibility" Width="110" Height="25" Margin="0,0,5,0" Click="BtnApplyVisibility_Click" Background="#0078D7" Foreground="White"/>
                        <Button Content="Apply Override" Width="110" Height="25" Click="BtnApplyLayerOverride_Click" Background="#D77800" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Bottom Buttons (shared) -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Apply (Tab 1)" HorizontalAlignment="Left" Width="100" Height="25" Click="BtnApply_Click" Background="#0078D7" Foreground="White"/>
            <Button Grid.Column="1" Content="Close" Width="80" Height="25" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
