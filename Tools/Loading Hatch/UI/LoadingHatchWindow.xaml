<Window x:Class="RincoNhan.Tools.LoadingHatch.UI.LoadingHatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Hatch (Filled Regions in Current View)" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Filled Region Types in Current View" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" AlternatingRowBackground="#FFF0F0F0"
                  GridLinesVisibility="All" BorderBrush="#FFCCCCCC" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName}" Width="*"/>
                <DataGridTextColumn Header="Type Mark" Binding="{Binding TypeMark}" Width="150"/>
                <DataGridTextColumn Header="Foreground Pattern" Binding="{Binding ForegroundPattern}" Width="150"/>
                <DataGridTextColumn Header="Background Pattern" Binding="{Binding BackgroundPattern}" Width="150"/>
                <DataGridTextColumn Header="Color (R,G,B)" Binding="{Binding Color}" Width="100"/>
                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Width="100" Height="30" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
