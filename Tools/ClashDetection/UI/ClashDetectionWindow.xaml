<Window x:Class="RincoNhan.Tools.ClashDetection.UI.ClashDetectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Clash Detection - Rinco Nhan" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="CLASH DETECTION" FontSize="24" FontWeight="Bold" Foreground="#2D3748"/>
            <TextBlock Text="Check interferences between Host and Linked models" Foreground="#718096"/>
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="1. Host Source" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock Text="Auto-detect Selection / View" Foreground="#A0AEC0" FontStyle="Italic"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0" Width="200">
                    <TextBlock Text="2. Select Link" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Links}" SelectedItem="{Binding SelectedLink}" DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0" Width="200">
                    <TextBlock Text="3. Link Category (Optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding LinkCategories}" SelectedItem="{Binding SelectedLinkCategory}" DisplayMemberPath="Name"/>
                </StackPanel>

                <Button Content="Run Check" Command="{Binding RunCheckCommand}" 
                        Background="#4299E1" Foreground="White" FontWeight="Bold"
                        Padding="20,0" Height="40" VerticalAlignment="Bottom"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- Results Grid -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
            <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" 
                      IsReadOnly="True" BorderThickness="0" Background="Transparent"
                      RowHeaderWidth="0" GridLinesVisibility="Horizontal" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Host Category" Binding="{Binding HostCategory}" Width="120"/>
                    <DataGridTextColumn Header="Host ID" Binding="{Binding HostElementId}" Width="100"/>
                    <DataGridTextColumn Header="Link Category" Binding="{Binding LinkCategory}" Width="120"/>
                    <DataGridTextColumn Header="Link ID" Binding="{Binding LinkElementId}" Width="100"/>
                    <DataGridTextColumn Header="Link File" Binding="{Binding LinkDocumentName}" Width="*"/>
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Show" 
                                        Command="{Binding DataContext.ShowClashCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#EDF2F7" Foreground="#2B6CB0" FontSize="11" Padding="5,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer / Status -->
        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#4A5568"/>
        </StatusBar>
    </Grid>
</Window>
