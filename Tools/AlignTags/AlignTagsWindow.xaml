<Window x:Class="RincoNhan.Tools.AlignTags.AlignTagsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Align Tags" 
        SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        Foreground="#1F2937"
        ResizeMode="NoResize"
        Topmost="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Status -->
            <RowDefinition Height="Auto"/> <!-- Steps -->
            <RowDefinition Height="Auto"/> <!-- Execute -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="ALIGN TAGS" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#111827"/>

        <!-- Status Notification Bar -->
        <Border Grid.Row="1" Background="#F3F4F6" CornerRadius="6" Margin="0,0,0,20" Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ " Foreground="#2563EB" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#1F2937" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Steps Content -->
        <StackPanel Grid.Row="2">
            <!-- Step 1 & 2: Selection -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="BƯỚC 1" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <Button Command="{Binding PickReferenceCommand}" Content="Pick Standard Tag" Height="40"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="BƯỚC 2" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <Button Command="{Binding PickTargetsCommand}" Content="Select Other Tags" Height="40"/>
                </StackPanel>
            </Grid>

            <!-- Step 3: Direction -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="BƯỚC 3: PHƯƠNG CĂN CHỈNH" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Margin="0,0,0,8"/>
                <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="15,10" Background="#F9FAFB">
                    <UniformGrid Columns="2">
                        <RadioButton Content="Ngang (Horizontal)" IsChecked="{Binding IsAlignHorizontal}" VerticalAlignment="Center"/>
                        <RadioButton Content="Dọc (Vertical)" IsChecked="{Binding IsAlignVertical}" VerticalAlignment="Center"/>
                    </UniformGrid>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Step 4: Execute -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="BƯỚC 4" FontSize="11" FontWeight="Bold" Foreground="#6B7280" Margin="0,0,0,5"/>
            <Button Command="{Binding AlignCommand}" Content="ALIGN TAGS NOW" Style="{StaticResource PrimaryButton}" Height="45"/>
        </StackPanel>
    </Grid>
</Window>
