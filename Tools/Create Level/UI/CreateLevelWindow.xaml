<Window x:Class="RincoNhan.Tools.CreateLevel.UI.CreateLevelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create Levels from Excel" Height="680" Width="850"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        Background="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FDFDFD"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E5C9A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#2E5C9A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="18"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E3C6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="SelectionMode" Value="Extended"/>
        </Style>

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5F7F9"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Settings -->
        <Grid Grid.Column="0" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Banner -->
            <Border Grid.Row="0" Height="60" Background="#2E5C9A">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="CREATE LEVELS" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="from Excel" Foreground="#A0C4E8" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">

                    <!-- Source Excel Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="SOURCE EXCEL" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding ExcelFilePath}" IsReadOnly="True" Height="28" 
                                         VerticalContentAlignment="Center" Padding="5,0" FontSize="11"
                                         Background="#FAFAFA" BorderBrush="#E0E0E0"/>
                                <Button Content="..." Command="{Binding BrowseCommand}" Grid.Column="1" 
                                        Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Width="30" Height="28"/>
                            </Grid>
                            <TextBlock Text="Sheet:" Margin="0,10,0,4" Foreground="#34495E" FontSize="11"/>
                            <ComboBox ItemsSource="{Binding Worksheets}" SelectedItem="{Binding SelectedWorksheet}" 
                                      Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Options Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="OPTIONS" Style="{StaticResource SectionLabel}"/>
                            <CheckBox Content="Delete all existing levels before creating" 
                                      IsChecked="{Binding DeleteExistingLevels}" 
                                      Margin="0,4" FontSize="11" Foreground="#E74C3C" FontWeight="SemiBold"/>
                            <TextBlock Text="⚠ Levels referenced by views cannot be deleted" 
                                       Foreground="#95A5A6" FontSize="9" Margin="20,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Existing Levels Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="EXISTING LEVELS IN PROJECT" Style="{StaticResource SectionLabel}"/>
                            <ItemsControl ItemsSource="{Binding ExistingLevels}" MaxHeight="150">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#34495E" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Elevation, StringFormat={}{0:F0} mm}" 
                                                       FontSize="10" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="(no levels)" Foreground="#BDC3C7" FontSize="10" Margin="0,4,0,0"
                                       Visibility="{Binding ExistingLevels.Count, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        </StackPanel>
                    </Border>

                    <!-- Summary -->
                    <TextBlock Text="{Binding SummaryText}" Foreground="#2E5C9A" FontSize="11" FontWeight="SemiBold" 
                               TextAlignment="Center" Margin="0,4"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#7F8C8D" FontSize="10" 
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,4" MinHeight="20"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Actions -->
            <Border Grid.Row="2" Padding="15" Background="#F8FAFC" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <StackPanel>
                    <Button Content="✓  Create Levels" Command="{Binding CreateLevelsCommand}" 
                            Style="{StaticResource PrimaryButtonStyle}" Height="42" FontSize="14" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Select All" Command="{Binding SelectAllCommand}" 
                                Style="{StaticResource SecondaryButtonStyle}" Height="30" FontSize="11" Margin="0,0,4,0"/>
                        <Button Content="Deselect All" Command="{Binding DeselectAllCommand}" Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}" Height="30" FontSize="11" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Right Panel: Level Preview -->
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Preview Header -->
            <Border Grid.Row="0" Background="White" CornerRadius="8,8,0,0" Padding="14" 
                    BorderBrush="#E0E0E0" BorderThickness="1,1,1,0">
                <TextBlock Text="LEVEL PREVIEW" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            </Border>

            <!-- Preview DataGrid -->
            <Border Grid.Row="1" Background="White" CornerRadius="0,0,8,8" BorderBrush="#E0E0E0" BorderThickness="1">
                <DataGrid ItemsSource="{Binding LevelDataList}" Style="{StaticResource DataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                        <DataGridTextColumn Header="Level Name" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Floor Height (mm)" Binding="{Binding FloorHeight, StringFormat={}{0:F0}}" Width="130" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,10,0"/>
                                    <Setter Property="Foreground" Value="#7F8C8D"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Elevation (mm)" Binding="{Binding Elevation, StringFormat={}{0:F0}}" Width="130" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,10,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#2E5C9A"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
